function runBirth(){const opts={name:document.getElementById('bName').value,date:document.getElementById('bDate').value,time:document.getElementById('bTime').value};const geo=document.getElementById('bGeo').value.match(/^(-?\d+(?:\.\d+)?)\s*[,;]\s*(-?\d+(?:\.\d+)?)$/);if(geo){opts.lat=parseFloat(geo[1]);opts.lon=parseFloat(geo[2]);}const b=ORC.birthProfile(opts);const el=document.getElementById('birthResult');if(!b.ok){el.innerHTML='<div class="empty">'+h(b.message)+'</div>';return;}el.innerHTML=`<div class="kv">${kv('DR',b.numbers.dr)}${kv('LP',b.numbers.lifePath)}${kv('Soul',b.numbers.soul)}${kv('Destiny',b.numbers.destiny)}${kv('Личный год',b.cycles.personalYear)}${kv('9-лет фаза',b.cycles.nineYearPhase)}${kv('Ось',b.numbers.axis.name)}</div><div class="insight">${b.insight.map(x=>h(x)).join('<br>')}</div>`;const sp=document.getElementById('birthSpectrum');sp.innerHTML='';for(let i=1;i<=9;i++){const pct=b.spectrum[i]*100;sp.innerHTML+=`<div class="bar"><div class="fill" style="height:${pct}%"></div><div class="num">${i}</div></div>`;}}
