<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ORACULUM ∞ v2 — Deep Unified Field Engine</title>
<style>
:root{--bg:#08090d;--surface:#11131b;--raised:#181b27;--panel:#0e1016;--border:rgba(255,255,255,0.08);--text:#f4f1ea;--muted:rgba(244,241,234,0.62);--gold:#d7b05a;--gold-glow:rgba(215,176,90,0.18);--cyan:#62cfdf;--green:#78c693;--orange:#e2985e;--red:#ec7b6e;--font:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;--mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace}
*{box-sizing:border-box}html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:var(--font)}
body{min-height:100vh;background:radial-gradient(1400px 700px at 8% -14%,rgba(215,176,90,0.14),transparent 58%),radial-gradient(900px 500px at 110% 0%,rgba(98,207,223,0.10),transparent 52%),var(--bg)}
.wrap{max-width:1280px;margin:0 auto;padding:28px 22px 80px}
header{display:grid;gap:14px;margin-bottom:30px}
.badge{display:inline-flex;align-items:center;gap:8px;width:fit-content;padding:6px 14px;border:1px solid rgba(215,176,90,0.35);border-radius:999px;background:var(--gold-glow);color:var(--gold);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;font-weight:700}
h1{margin:0;font-size:clamp(34px,5.5vw,56px);line-height:1.05;font-weight:750;letter-spacing:-0.03em}h1 span{col