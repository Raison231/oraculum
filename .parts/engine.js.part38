function bodyClock(birth, date) { var h = healthRhythm(birth, date); var c = chronobiology(birth, date); return {ok: true, health: h, schedule: c, summary: "–°–Є–ї—М–љ–∞—П —Б—В–Њ—А–Њ–љ–∞: " + (h.physical > h.emotional ? "—В–µ–ї–Њ" : (h.emotional > h.intellectual ? "—Н–Љ–Њ—Ж–Є–Є" : "–Є–љ—В–µ–ї–ї–µ–Ї—В"))}; }
