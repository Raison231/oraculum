mpty">'+h(b.message)+'</div>';return;}el.innerHTML=`<div class="kv">${kv('DR',b.numbers.dr)}${kv('LP',b.numbers.lifePath)}${kv('Soul',b.numbers.soul)}${kv('Destiny',b.numbers.destiny)}${kv('Личный год',b.cycles.personalYear)}${kv('9-лет фаза',b.cycles.nineYearPhase)}${kv('Ось',b.numbers.axis.name)}</div><div class="insight">${b.insight.map(x=>h(x)).join('<br>')}</div>`;const sp=document.getElementById('birthSpectrum');sp.innerHTML='';for(let i=1;i<=9;i++){const pct=b.spectrum[i]*100;sp.innerHTML+=`<div class="bar"><div class="fill" style="height:${pct}%"></div><div class="num">${i}</div></div>`;}}
function runPredict(){const from=document.getElementById('pFrom').value;const days=+document.getElementById('pDays').value;const p=ORC.predict({from:from||new Date(),days:days,birth:'1998-04-10'});const tb=document.querySelector('#predictTable tbody');tb.innerHTML='';p.calendar.forEach(r=>{const cls=r.overall>=78?'peak':(r.moneyScore>=90?'money':'');tb.innerHTML+=`<tr class="${cls}"><td>${h(r.date)}</td><td>${r.dr}</td><td>${h(r.luna)}</td><td>${r.overall}</td><td>${r.rings}</td><td>${h(r.money)}</td><td>${h(r.verdict)}</td></tr>`;});document.getElementById('predictBest').innerHTML=`<div class="kv">${kv('Запуск',p.best.launch.date)}${kv('Деньги',p.best.money.date)}${kv('Релиз',p.best.release.date)}${