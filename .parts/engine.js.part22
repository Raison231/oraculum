  var st = step21(baseN); lenses.push({key: "key21", title: "Второй Ключ", lines: ["Шаг " + st.step + "/21 · " + st.phaseName, "Оп: " + st.operation, OPS_TIPS[st.operation] || ""]}); scores.push(st.step % 7 === 0 ? 90 : 62);
