function runCode(){const c=ORC.codeResonance(document.getElementById('txCode').value);renderBrandText(c);}
function renderBrandText(r){const el=document.getElementById('brandResult');if(!r.ok){el.innerHTML='<div class="empty">'+h(r.message)+'</div>';return;}if(r.score!=null)renderVerdict(el,r,r.score);else el.innerHTML='';let html='<div class="kv">';if(r.dr!=null)html+=kv('DR',r.dr);if(r.words!=null)html+=kv('Слов',r.words);if(r.lines!=null)html+=kv('Строк',r.lines);if(r.functions!=null)html+=kv('Функций',r.functions);if(r.frequency)html+=kv('Частота',r.frequency.hz+' '+r.frequency.name);if(r.suggestedDomain)html+=kv('Домен',r.suggestedDomain);if(r.verdict)html+=kv('Вердикт',r.verdict);html+='</div>';if(r.meaning)html+=`<div class="insight">${h(r.meaning)}</div>`;if(r.action)html+=`<div class="insight">${h(r.action)}</div>`;if(r.tips)html+=`<div class="kv">${r.tips.map(x=>pill(x,'#62cfdf')).join('')}</div>`;if(r.color)html+=`<div class="kv"><span class="color-swatch" style="background:${h(r.color.hex)}"></span>${h(r.color.name)}</div>`;if(r.cards)html+=`<div class="kv">${r.cards.map(c=>pill(c.position+': '+c.card,'#c75aff')).join('')}</div>`;if(r.symbols)html+=`<div class="kv">${r.symbols.map(s=>pill(s,'#e2985e')).join('')}</div>