lass="insight">${h(r.action)}</div>`;if(r.tips)html+=`<div class="kv">${r.tips.map(x=>pill(x,'#62cfdf')).join('')}</div>`;if(r.color)html+=`<div class="kv"><span class="color-swatch" style="background:${h(r.color.hex)}"></span>${h(r.color.name)}</div>`;if(r.cards)html+=`<div class="kv">${r.cards.map(c=>pill(c.position+': '+c.card,'#c75aff')).join('')}</div>`;if(r.symbols)html+=`<div class="kv">${r.symbols.map(s=>pill(s,'#e2985e')).join('')}</div>`;el.innerHTML+=html;}
function runMoney(){const amount=+document.getElementById('mAmount').value;const date=document.getElementById('mDate').value;const r=ORC.investmentTiming(amount,{date:'1998-04-10'},date||new Date());const el=document.getElementById('moneyResult');if(!r.ok){el.innerHTML='<div class="empty">'+h(r.message)+'</div>';return;}renderVerdict(el,r,r.score);el.innerHTML+=`<div class="kv">${kv('Сумма',r.amount)}${kv('Риск',r.risk)}${kv('DR ��обытия',r.dr)}${kv('DR денег',r.moneyDR)}${kv('Совет',r.action)}</div>`;}
