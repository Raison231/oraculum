function runSynastry(){const a=document.getElementById('sA').value,b=document.getElementById('sB').value;const s=ORC.synastry({date:a},{date:b});const el=document.getElementById('synastryResult');if(!s.ok){el.innerHTML='<div class="empty">'+h(s.message)+'</div>';return;}el.innerHTML=`<div class="verdict show ${s.score>=85?'ok':(s.score>=60?'mid':'bad')}"><div class="row"><span class="tag">${h(s.verdict)}</span><span class="score">${s.score}</span></div></div><div class="kv">${kv('A DR',s.drA)}${kv('B DR',s.drB)}${kv('Совмес��имость',s.compatibility)}</div><div class="insight">${s.lines.map(x=>h(x)).join('<br>')}</div>`;}
function runTeam(){const raw=document.getElementById('tMembers').value;const members=raw.split(',').map(d=>({date:d.trim()})).filter(x=>x.date);const t=ORC.teamField(members);const el=document.getElementById('synastryResult');if(!t.ok){el.innerHTML='<div class="empty">'+h(t.message)+'</div>';return;}el.innerHTML=`<div class="verdict show ${t.missing.length<=2?'ok':'mid'}"><div class="row"><span class="tag">${h(t.verdict)}</span></div></div><div class="kv">${kv('Team DR',t.te