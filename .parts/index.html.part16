kv('Сделка',p.best.deal.date)}${kv('Deep Work',p.best.deepWork.date)}</div>`;document.getElementById('predictBest').className='result show';}
function runCreate(){const i=document.getElementById('cIntent').value;const c=ORC.createDesign({intent:i});const el=document.getElementById('createResult');if(!c.ok){el.innerHTML='<div class="empty">'+h(c.message)+'</div>';return;}el.innerHTML=`<div class="kv">${kv('DR',c.dr)}${kv('Ось',c.axis.name)}${kv('Частота',c.frequency.hz+' '+c.frequency.name)}${kv('Действие',c.action)}</div><div class="insight">${h(c.mantra)}</div><h3>9 модулей</h3>`+c.modules.map(m=>`<div class="module"><span class="num">${m.n}</span><strong>${h(m.role)}</strong> — ${h(m.layer)}: ${h(m.task)}</div>`).join('')+`<h3>21 шаг</h3><div class="table-wrap"><table><thead><tr><th>Шаг</th><th>Дата</th><th>Оп</th><th>Совет</th></tr></thead><tbody>${c.roadmap.slice(0,21).map(s=>`<tr><td>${s.step}</td><td>${h(s.date)}</td><td>${h(s.operation)}</td><td>${h(s.tip)}</td></tr>`).join('')}</tbody></table></div>`;}
function runSynastry(){const a=document.getElementById('sA').value,b=document.getElementById('sB').value;const s=ORC.synastry({date:a},{date:b});const el=document.getElementById('synastryResult');if(!s.ok){el.innerHTML='<div class="empty">'+h(s.message)+'</div>';return;}el.