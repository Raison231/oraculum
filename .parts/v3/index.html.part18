id';el.innerHTML=`<div class="verdict show ${cls}"><div class="row"><span class="tag">${h(r.verdict)}</span><span class="score">${score!=null?Math.round(score):''}</span></div><div class="meta">${h(r.action||'')}</div></div>`;}
function renderLenses(el, r){let html='<div class="lenses">';r.lenses.forEach(l=>{html+=`<div class="lens"><div class="lens-head"><span class="dot"></span><h3>${h(l.title)}</h3></div><ul>`;l.lines.forEach(line=>html+=`<li>${h(line)}</li>`);html+='</ul></div>';});html+='</div>';el.innerHTML+=html;}
function runField(){const raw=document.getElementById('fieldInput').value;const r=ORC.fieldRead(raw);const el=document.getElementById('fieldResult');if(!r.ok){el.innerHTML='<div class="empty">'+h(r.message)+'</div>';return;}renderVerdict(el,r,r.overall);renderLenses(el,r);}
