function runTeam(){const raw=document.getElementById('tMembers').value;const members=raw.split(',').map(d=>({date:d.trim()})).filter(x=>x.date);const t=ORC.teamField(members);const el=document.getElementById('synastryResult');if(!t.ok){el.innerHTML='<div class="empty">'+h(t.message)+'</div>';return;}el.innerHTML=`<div class="verdict show ${t.missing.length<=2?'ok':'mid'}"><div class="row"><span class="tag">${h(t.verdict)}</span></div></div><div class="kv">${kv('Team DR',t.teamDR)}${kv('Размер',t.size)}</div><div class="insight">Команда: ${t.drProfile.map(d=>pill('DR'+d,COLORS[d-1].hex)).join('')}<br>Недостаёт: ${t.missing.map(d=>pill('DR'+d,COLORS[d-1].hex)).join('')}</div>`;}
