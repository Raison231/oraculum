      <hr style="border:0;border-top:1px solid var(--border);margin:18px 0">
      <button class="secondary" onclick="runMoneyMap()">Карта денег 30 дней</button>
    </div>
    <div class="card"><h2>📊 Результат</h2><div id="moneyResult