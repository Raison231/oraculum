adline score</button>
      <hr style="border:0;border-top:1px solid var(--border);margin:18px 0">
      <label>Код</label><textarea id="txCode" placeholder="function example() { ... }"></textarea>
      <button class="primary" style="margin-top:10px" onclick="runCode()">Code Resonance</button>
    </div>
    <div class="card"><h2>🎙 Результат</h2><div id="brandResult"></div></div>
  </div>
</section>

<!-- MONEY -->
