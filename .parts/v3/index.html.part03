gin:0 0 14px;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);font-weight:800}
.card h3{margin:14px 0 8px;font-size:14px;color:var(--text);font-weight:700}
label{display:block;font-size:12px;color:var(--muted);margin-bottom:7px;font-weight:600}
.input-row{display:flex;gap:10px;flex-wrap:wrap}
input[type=text],input[type=date],input[type=time],input[type=number],select,textarea{flex:1;min-width:120px;background:var(--panel);color:var(--text);border:1px solid var(--border);border-radius:12px;padding:11px 13px;font-size:15px;outline:none;font-family:var(--font)}
input:focus,select:focus,textarea:focus{border-color:rgba(230,196,111,0.55);box-shadow:0 0 0 4px rgba(230,196,111,0.10)}
textarea{min-height:72px;resize:vertical;flex-basis:100%}
button.primary{background:linear-gradient(180deg,#e8c878,#c99a3d);color:#14110a;border:0;border-radius:12px;padding:0 20px;font-weight:800;font-size:14px;cursor:pointer;white-space:nowrap;min-height:44px;box-shadow:0 4px 18