,ctx=mapCtx;ctx.fillStyle='#0b0d12';ctx.fillRect(0,0,w,h);const cx=w/2,cy=h/2,scale=Math.min(w,h)/3.2;ctx.strokeStyle='rgba(230,196,111,0.15)';ctx.beginPath();for(let i=0;i<ORC.NODES.length;i++){const n=ORC.NODES[i];const x=cx+n.lon/180*scale*1.8;const y=cy-n.lat/90*scale;ctx.moveTo(x,cy);ctx.lineTo(x,y);ctx.stroke();ctx.fillStyle=n.cls==='icosa'?'#e6c46f':(n.cls==='dodeca'?'#62cfdf':'#c75aff');ctx.beginPath();ctx.arc(x,y,2.5,0,Math.PI*2);ctx.fill();}}
window.addEventListener('resize',resizeMap);setTimeout(resizeMap,100);

