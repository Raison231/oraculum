вет',r.action)}</div>`;}
function runMoneyMap(){const m=ORC.moneyMap({date:'1998-04-10'},30);const el=document.getElementById('moneyResult');if(!m.ok){el.innerHTML='<div class="empty">'+h(m.message)+'</div>';return;}el.innerHTML=`<div class="insight">${h(m.verdict)}</div><div class="kv">${kv('Best DR',m.bestMoneyDR)}${kv('Дней',m.days)}</div><div class="spectrum">${m.buckets.map((v,i)=>`<div class="bar"><div class="fill" style="height:${v/3}%"></div><div class="num">${i+1}</div></div>`).join('')}</div>`;}
function runHealth(){const r=ORC.healthRhythm({date:'1998-04-10'},document.getElementById('hDate').value||new Date());renderHealth(r);}
function runBodyClock(){const r=ORC.bodyClock({date:'1998-04-10'},document.getElementById('hDate').value||new Date());renderHealth(r);}
