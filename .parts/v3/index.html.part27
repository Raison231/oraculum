function runRoute(){const raw=document.getElementById('rRoute').value;const pts=raw.split(';').map((s,i)=>{const m=s.match(/^(-?\d+(?:\.\d+)?)\s*[,;]\s*(-?\d+(?:\.\d+)?)$/);return m?{name:'T'+(i+1),lat:parseFloat(m[1]),lon:parseFloat(m[2])}:null;}).filter(Boolean);const r=ORC.routeScore(pts);renderRoute(r);}
function runManifest(){const r=ORC.manifestation369(document.getElementById('rIntent').value,21);renderRoute(r);}
