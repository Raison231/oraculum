({key: "time", title: "Время", lines: ["DR: " + tdr + " — " + DR_MEANING[tdr], "Планетный час: " + PLANETS[(p.h + p.m) % 7], "Совет: " + DR_ACTION[tdr]]}); scores.push(60); }
