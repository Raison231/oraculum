  return {ok: true, input: p, seed: seed, dr: dr, axis: ax, overall: Math.round(overall * 10) / 10, verdict: verdict, lenses: lenses, money: MONEY_DR[dr], meaning: DR_MEANING[dr], action: DR_ACTION[dr]};
