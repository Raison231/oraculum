div></div>
  </div>
</section>

<!-- ROUTE / MANIFEST -->
<section id="tab-route" class="section">
  <div class="grid">
    <div class="card">
      <h2>🗺 Маршрут / Манифест / Пространство</h2>
      <label>Маршрут (lat,lon;lat,lon)</label><input id="rRoute" type="text" placeholder="41.72,44.83;46.54,61.17">
      <button class="primary" style="margin-top:10px" onclick="runRoute()">Route Score</button>
      <hr style="border:0;border-top:1px solid var(--border);margin:18px 0">
      <label>Намерение (369)</label><input id="rIntent" type="text" placeholder="рост дохода">
      <button class="secondary" onclick="runManifest()">369 план</button>
      <hr style="border:0;border-top:1px solid var(--border);margin:18px 0">
      <label>Помещение / еда</label><input id="rSpace" type="text" placeholder="комната с большим окном на восток">
      <button class="secondary" onclick="runSpace()">Space Plan</button>
      <button class="secondary" onclick="runFood()">Food</button>
      <button class="secondary" onclick="runCommit()">Commit Timing</button>
    </div>
    <div class="card"><h2>📍 Ре��ультат</h2><div id="routeResult"></div></div>
  </div>
</section>

