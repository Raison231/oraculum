function randomOracle(seed) { seed = seed != null ? seed : Math.floor(Date.now() / 1000); var rng = seededRandom(seed); var dr = digitalRoot(Math.floor(rng * 100) + 1); var rune = RUNES[Math.floor(rng * 100000) % RUNES.length]; var el = elementOf(dr); var advice = DR_ACTION[dr]; return {ok: true, seed: seed, dr: dr, rune: rune, element: el, meaning: DR_MEANING[dr], advice: advice, verdict: rng > 0.61 ? "–ó–Ě–ź–ö" : (rng > 0.38 ? "–°–ě–í–ē–Ę" : "–ü–ź–£–ó–ź")}; }
function runeDraw(seed) { seed = seed != null ? seed : Math.floor(Date.now() / 1000); return {ok: true, rune: RUNES[Math.floor(seededRandom(seed) * RUNES.length)], dr: digitalRoot(seed)}; }
function routeScore(places) { if (!places || places.length < 2) return {ok: false, message: "–Ě—É–∂–Ĺ–ĺ –ľ–ł–Ĺ–ł–ľ—É–ľ 2 —ā–ĺ—á–ļ–ł"}; var total = 0, legs = [];
  for (var i = 0; i < places.length - 1; i++) { var a = places[i], b = places[i + 1]; var leg = leyLine(a.lat, a.lon, b.lat, b.lon); total += leg.nodeScore; legs.push({from: a.name || "A", to: b.name || "B", leg: leg}); }
  var avg = Math.round(total / (places.length - 1)); return {ok: true, places: places, legs: legs, score: avg, verdict: avg >= 75 ? "–ú–ź–†–®–†–£–Ę –í –†–ē–ó–ě–Ě–ź–Ě–°–ē" : (avg >= 50 ? "–ú–ź–†–®–†–£–Ę –†–